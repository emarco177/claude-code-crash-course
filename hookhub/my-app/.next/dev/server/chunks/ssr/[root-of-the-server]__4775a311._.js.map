[{"id":"bash-command-validator","name":"Bash Command Validator","description":"Validates bash commands against security and performance patterns. Blocks dangerous commands and suggests safer alternatives like using 'rg' instead of 'grep'.","category":"security","repoUrl":"https://github.com/anthropics/claude-code/blob/main/examples/hooks/bash_command_validator_example.py","author":"anthropic"},{"id":"command-logger","name":"Command Logger","description":"Logs all bash commands with their descriptions to a file for audit trails and debugging. Useful for tracking what Claude executes.","category":"logging","repoUrl":"https://github.com/anthropics/claude-code/tree/main/examples/hooks","author":"anthropic"},{"id":"auto-prettier","name":"Auto Prettier","description":"Automatically runs Prettier on TypeScript and JavaScript files after Claude edits them. Ensures consistent code formatting.","category":"formatting","repoUrl":"https://github.com/anthropics/claude-code/tree/main/examples/hooks","author":"anthropic"},{"id":"file-protection","name":"File Protection","description":"Blocks edits to sensitive files like .env, package-lock.json, and .git/ directories. Prevents accidental modification of critical files.","category":"security","repoUrl":"https://github.com/anthropics/claude-code/tree/main/examples/hooks","author":"anthropic"},{"id":"desktop-notifications","name":"Desktop Notifications","description":"Sends desktop notifications using notify-send when Claude is waiting for input or needs attention. Works on Linux systems.","category":"notifications","repoUrl":"https://github.com/anthropics/claude-code/tree/main/examples/hooks","author":"anthropic"},{"id":"markdown-fixer","name":"Markdown Code Block Fixer","description":"Detects programming languages in unlabeled code blocks and adds appropriate language tags. Also fixes excessive blank lines in markdown.","category":"formatting","repoUrl":"https://github.com/anthropics/claude-code/tree/main/examples/hooks","author":"anthropic"},{"id":"session-context-injector","name":"Session Context Injector","description":"Injects relevant context at session start, such as environment variables, project-specific instructions, or team guidelines.","category":"context","repoUrl":"https://github.com/anthropics/claude-code/tree/main/examples/hooks","author":"anthropic"},{"id":"nvm-setup","name":"NVM Auto Setup","description":"Automatically sets up Node Version Manager at session start, ensuring the correct Node.js version is used for the project.","category":"automation","repoUrl":"https://github.com/anthropics/claude-code/tree/main/examples/hooks","author":"community"},{"id":"production-blocker","name":"Production File Blocker","description":"Blocks modifications to production configuration files and enforces organization-specific deployment rules.","category":"permissions","repoUrl":"https://github.com/anthropics/claude-code/tree/main/examples/hooks","author":"community"},{"id":"eslint-runner","name":"Auto ESLint","description":"Runs ESLint automatically after file edits and provides feedback to Claude about linting errors that need to be fixed.","category":"formatting","repoUrl":"https://github.com/anthropics/claude-code/tree/main/examples/hooks","author":"community"},{"id":"test-runner","name":"Auto Test Runner","description":"Automatically runs relevant tests after code changes and reports results back to Claude for immediate feedback.","category":"automation","repoUrl":"https://github.com/anthropics/claude-code/tree/main/examples/hooks","author":"community"},{"id":"git-guard","name":"Git Guard","description":"Prevents dangerous git operations like force push to main, hard resets, and other potentially destructive commands.","category":"security","repoUrl":"https://github.com/anthropics/claude-code/tree/main/examples/hooks","author":"community"}]